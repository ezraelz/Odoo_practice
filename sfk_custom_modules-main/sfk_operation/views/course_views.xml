<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Form View -->
        <record id="sfk_operation_course_view_form" model="ir.ui.view">
            <field name="name">sfk_operation.course.view.form</field>
            <field name="model">sfk_operation.course</field>
            <field name="arch" type="xml">
                <form string="Course">
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- List View -->
        <record id="sfk_operation_course_view_list" model="ir.ui.view">
            <field name="name">sfk_operation.course.view.list</field>
            <field name="model">sfk_operation.course</field>
            <field name="arch" type="xml">
                <list string="Courses">
                    <field name="name"/>
                </list>
            </field>
        </record>

        <!-- Action -->
        <record id="sfk_operation_course_action" model="ir.actions.act_window">
            <field name="name">Courses</field>
            <field name="res_model">sfk_operation.course</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>

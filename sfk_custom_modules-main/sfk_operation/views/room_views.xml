<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- sfk.room -->
        <record id="sfk_operation_room_action" model="ir.actions.act_window">
            <field name="name">Rooms</field>
            <field name="res_model">sfk.room</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="sfk_room_view_list" model="ir.ui.view">
            <field name="name">sfk.room.list</field>
            <field name="model">sfk.room</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="capacity"/>
                </list>
            </field>
        </record>

        <record id="sfk_room_view_form" model="ir.ui.view">
            <field name="name">sfk.room.form</field>
            <field name="model">sfk.room</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="capacity"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
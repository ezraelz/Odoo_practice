<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- sfk.student -->
        <record id="sfk_operation_student_action" model="ir.actions.act_window">
            <field name="name">Students</field>
            <field name="res_model">sfk.student</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="sfk_student_view_list" model="ir.ui.view">
            <field name="name">sfk.student.list</field>
            <field name="model">sfk.student</field>
            <field name="arch" type="xml">
                <list decoration-info="status == 'active'" decoration-warning="status == 'withdrawn'" decoration-success="status == 'completed'">
                    <field name="name"/>
                    <field name="program_id"/>
                    <field name="age"/>
                    <field name="enrollment_date"/>
                    <field name="status" widget="badge"/>
                </list>
            </field>
        </record>

        <record id="sfk_student_view_form" model="ir.ui.view">
            <field name="name">sfk.student.form</field>
            <field name="model">sfk.student</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_set_active" string="Activate" type="object" invisible="status == 'active'" class="btn-primary"/>
                        <button name="action_set_withdrawn" string="Withdraw" type="object" invisible="status == 'withdrawn'"/>
                        <button name="action_set_completed" string="Mark Completed" type="object" invisible="status == 'completed'"/>
                        <field name="status" widget="statusbar" statusbar_visible="active,withdrawn,completed"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="parent_name"/>
                                <field name="parent_phone"/>
                                <field name="program_id"/>
                                <field name="date_of_birth"/>
                                <field name="age" readonly="1"/>
                            </group>
                            <group>
                                <field name="enrollment_date"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Enrollments">
                                <field name="enrollment_ids" context="{'default_program_id': program_id}">
                                    <list editable="bottom">
                                        <field name="program_id" readonly="1" force_save="1"/>
                                        <field name="center_id" readonly="1" force_save="1"/>
                                        <field name="term_id" domain="[('program_id', '=', program_id)]"/>
                                        <field name="available_course_ids" column_invisible="True"/>
                                        <field name="course_id" domain="[('id', 'in', available_course_ids)]"/>
                                        <field name="enrollment_date"/>
                                        <field name="status"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>

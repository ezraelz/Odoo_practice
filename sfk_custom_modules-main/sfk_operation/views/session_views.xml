<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- sfk.session -->
        <record id="sfk_operation_program_session_action" model="ir.actions.act_window">
            <field name="name">Program Sessions</field>
            <field name="res_model">sfk.session</field>
            <field name="view_mode">list,form,calendar</field>
        </record>

<!--        <record id="sfk_operation_today_session_action" model="ir.actions.act_window">-->
<!--            <field name="name">My Today's Sessions</field>-->
<!--            <field name="res_model">sfk.session</field>-->
<!--            <field name="view_mode">list,form</field>-->
<!--            <field name="domain">[('start_datetime', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')), ('start_datetime', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59')), '|', ('lead_instructor_id.user_id', '=', uid), ('assistant_instructor_id.user_id', '=', uid)]</field>-->
<!--            <field name="context">{'search_default_confirmed': 1}</field>-->
<!--        </record>-->

        <record id="sfk_operation_attendance_marking_action" model="ir.actions.act_window">
            <field name="name">Take Attendance (Today)</field>
            <field name="res_model">sfk.session</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('program_type', '=', 'center'), ('start_datetime', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')), ('start_datetime', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59')), '|', ('lead_instructor_id.user_id', '=', uid), ('assistant_instructor_id.user_id', '=', uid)]</field>
            <field name="context">{'search_default_confirmed': 1}</field>
        </record>

        <record id="sfk_session_view_list" model="ir.ui.view">
            <field name="name">sfk.session.list</field>
            <field name="model">sfk.session</field>
            <field name="arch" type="xml">
                <list decoration-info="state == 'draft'" decoration-success="state == 'done'">
                    <field name="name"/>
                    <field name="program_id"/>
                    <field name="term_id"/>
                    <field name="course_id"/>
                    <field name="grade" optional="show"/>
                    <field name="start_datetime"/>
                    <field name="lead_instructor_id"/>
                    <field name="attendance_count" string="Present"/>
                    <field name="attendance_progress" widget="progressbar" string="Progress"/>
                    <button name="action_confirm" string="Load Attendance" type="object" class="btn-primary" invisible="state != 'draft' or program_type == 'school'"/>
                    <field name="state" widget="badge"/>
                </list>
            </field>
        </record>
        
        <record id="sfk_session_view_calendar" model="ir.ui.view">
            <field name="name">sfk.session.calendar</field>
            <field name="model">sfk.session</field>
            <field name="arch" type="xml">
                <calendar string="Sessions" date_start="start_datetime" date_stop="end_datetime" color="program_id">
                    <field name="name"/>
                </calendar>
            </field>
        </record>

        <record id="sfk_session_view_form" model="ir.ui.view">
            <field name="name">sfk.session.form</field>
            <field name="model">sfk.session</field>
            <field name="arch" type="xml">
                <form>
                     <header>
                        <button name="action_confirm" string="Load Attendance List" type="object" class="btn-primary" invisible="state != 'draft' or program_type == 'school'"/>
                        <button name="action_confirm" string="Confirm Session" type="object" class="btn-primary" invisible="state != 'draft' or program_type != 'school'"/>
                        
                        <!-- Attendance Workflow -->
                        <button name="action_submit_attendance" string="Submit Attendance" type="object" class="btn-primary" 
                                invisible="attendance_state != 'draft' or state != 'confirmed'"/>
                        <button name="action_approve_attendance" string="Approve Attendance" type="object" class="btn-success" 
                                invisible="attendance_state != 'submitted' or program_type != 'center'" groups="sfk_operation.group_sfk_coach_manager"/>
                        
                        <!-- Validation Workflow -->
                        <button name="action_validate" string="Validate Actions" type="object" class="btn-info"
                                invisible="is_validated or state == 'draft'" groups="sfk_operation.group_sfk_coach_manager"/>
                        
                        <!-- Instructor Change Workflow -->
                        <button name="action_approve_instructor_change" string="Approve Instructor Change" type="object" class="btn-warning"
                                invisible="not requested_lead_instructor_id and not requested_assistant_instructor_id"
                                groups="sfk_operation.group_sfk_manager"/>
                         <button name="action_reject_instructor_change" string="Reject Instructor Change" type="object" class="btn-danger"
                                invisible="not requested_lead_instructor_id and not requested_assistant_instructor_id"
                                groups="sfk_operation.group_sfk_manager"/>

                        <button name="action_done" string="Mark as Completed" type="object" class="btn-success" invisible="state != 'confirmed'"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state in ('done','cancelled')"/>
                        <button name="action_draft" string="Reset to Draft" type="object" invisible="state == 'draft'"/>

                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                        <field name="attendance_state" widget="statusbar" statusbar_visible="draft,submitted,approved" invisible="program_type != 'center'"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="program_id"/>
                                <field name="program_type" invisible="1"/>
                                <field name="term_id"/>
                                <field name="course_id"/>
                                <field name="grade" invisible="program_type != 'school'"/>
                            </group>
                            <group>
                                <field name="start_datetime"/>
                                <field name="end_datetime"/>
                                <field name="room_id"/>
                            </group>
                        </group>
                        <group>
                            <group string="Execution Tracking">
                                <field name="execution_state" widget="radio" options="{'horizontal': true}" readonly="state == 'done'"/>
                                <field name="reason_not_conducted" invisible="execution_state != 'not_conducted'" required="execution_state == 'not_conducted'" readonly="state == 'done'"/>
                                <field name="school_student_count" invisible="program_type != 'school'" groups="sfk_operation.group_sfk_coach_manager" readonly="state == 'done'"/>
                            </group>
                            <group string="Personnel Availability">
                                <label for="lead_instructor_id" string="Lead Instructor"/>
                                <div class="o_row">
                                    <!-- Editable by Op Manager, Readonly for others -->
                                    <field name="lead_instructor_id" readonly="not context.get('uid') == 1" groups="!sfk_operation.group_sfk_manager"/>
                                    <field name="lead_instructor_id" groups="sfk_operation.group_sfk_manager"/>
                                    
                                    <field name="lead_instructor_status" class="oe_inline" readonly="attendance_state == 'approved'"/>
                                    <field name="lead_substitute_id" invisible="lead_instructor_status != 'substituted'" required="lead_instructor_status == 'substituted'" placeholder="Substitute" readonly="attendance_state == 'approved'"/>
                                </div>
                                <field name="requested_lead_instructor_id" string="Requested Lead Change" groups="sfk_operation.group_sfk_coach_manager" invisible="attendance_state == 'approved'"/>

                                <label for="assistant_instructor_id" string="Assistant Instructor" invisible="not assistant_instructor_id"/>
                                <div class="o_row" invisible="not assistant_instructor_id">
                                    <field name="assistant_instructor_id" readonly="1" groups="!sfk_operation.group_sfk_manager"/>
                                    <field name="assistant_instructor_id" groups="sfk_operation.group_sfk_manager"/>
                                    
                                    <field name="assistant_instructor_status" class="oe_inline" readonly="attendance_state == 'approved'"/>
                                    <field name="assistant_substitute_id" invisible="assistant_instructor_status != 'substituted'" required="assistant_instructor_status == 'substituted'" placeholder="Substitute" readonly="attendance_state == 'approved'"/>
                                </div>
                                <field name="requested_assistant_instructor_id" string="Requested Asst. Change" groups="sfk_operation.group_sfk_coach_manager" invisible="not assistant_instructor_id or attendance_state == 'approved'"/>
                                <field name="is_validated" readonly="1" groups="sfk_operation.group_sfk_coach_manager"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Student Attendance" invisible="program_type == 'school' or is_future_session">
                                <field name="attendance_ids" readonly="attendance_state == 'approved'">
                                   <list editable="bottom" decoration-success="status == 'present'" decoration-danger="status == 'absent'" decoration-warning="status == 'late'">
                                        <field name="student_id" readonly="1"/>
                                        <field name="status" widget="radio" options="{'horizontal': true}"/>
                                        <field name="notes" placeholder="Reason for late/absent..."/>
                                        <field name="checked_by" column_invisible="True"/>
                                        <field name="checked_date" column_invisible="True"/>
                                   </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>

                </form>
            </field>
        </record>
    </data>
</odoo>

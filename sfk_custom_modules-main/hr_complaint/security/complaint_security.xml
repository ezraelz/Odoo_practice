<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_complaint_rule_employee_own" model="ir.rule">
        <field name="name">HR Complaint: Employee Own Records</field>
        <field name="model_id" ref="model_hr_complaint"/>
        <field name="domain_force">[("employee_user_id", "=", user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="hr_complaint_rule_manager_all" model="ir.rule">
        <field name="name">HR Complaint: HR Manager All Records</field>
        <field name="model_id" ref="model_hr_complaint"/>
        <field name="domain_force">[(1, "=", 1)]</field>
        <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
    </record>
</odoo>

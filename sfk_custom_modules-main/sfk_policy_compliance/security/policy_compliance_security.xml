<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_policy_assignment_user_own" model="ir.rule">
        <field name="name">Policy Assignment: own records</field>
        <field name="model_id" ref="model_policy_assignment"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('employee_user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_policy_assignment_hr_all" model="ir.rule">
        <field name="name">Policy Assignment: HR all records</field>
        <field name="model_id" ref="model_policy_assignment"/>
        <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>

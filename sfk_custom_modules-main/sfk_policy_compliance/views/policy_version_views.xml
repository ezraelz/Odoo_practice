<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_policy_version_search" model="ir.ui.view">
        <field name="name">policy.version.search</field>
        <field name="model">policy.version</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="document_id"/>
                <field name="category_id"/>
                <filter string="Draft" name="state_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Active" name="state_active" domain="[('state', '=', 'active')]"/>
                <filter string="Archived" name="state_archived" domain="[('state', '=', 'archived')]"/>
                <group expand="0" string="Group By">
                    <filter string="Policy" name="group_document" context="{'group_by': 'document_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Category" name="group_category" context="{'group_by': 'category_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_policy_version_list" model="ir.ui.view">
        <field name="name">policy.version.list</field>
        <field name="model">policy.version</field>
        <field name="arch" type="xml">
            <list default_order="effective_date desc">
                <field name="name"/>
                <field name="version_number"/>
                <field name="effective_date"/>
                <field name="mandatory_ack"/>
                <field name="target_scope"/>
                <field name="assignment_count"/>
                <field name="pending_count"/>
                <field name="overdue_count"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_policy_version_form" model="ir.ui.view">
        <field name="name">policy.version.form</field>
        <field name="model">policy.version</field>
        <field name="arch" type="xml">
            <form string="Policy Version">
                <header>
                    <button name="action_activate" type="object" string="Activate" class="btn-primary" invisible="state == 'active'" groups="hr.group_hr_user"/>
                    <button name="action_assign_now" type="object" string="Assign Now" invisible="state != 'active'" groups="hr.group_hr_user"/>
                    <button name="action_archive" type="object" string="Archive" invisible="state == 'archived'" groups="hr.group_hr_user"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="document_id"/>
                            <field name="version_number"/>
                            <field name="effective_date"/>
                        </group>
                        <group>
                            <field name="mandatory_ack"/>
                            <field name="ack_deadline_days" invisible="not mandatory_ack"/>
                            <field name="target_scope"/>
                        </group>
                    </group>
                    <group>
                        <field name="department_ids" widget="many2many_tags" invisible="target_scope != 'department'"/>
                        <field name="job_ids" widget="many2many_tags" invisible="target_scope != 'job'"/>
                        <field name="employment_type_ids" widget="many2many_tags" invisible="target_scope != 'employment_type'"/>
                    </group>
                    <group>
                        <field name="change_summary"/>
                    </group>
                    <group>
                        <field name="policy_file" filename="filename"/>
                        <field name="filename" invisible="1"/>
                    </group>
                    <notebook>
                        <page string="Assignments">
                            <field name="assignment_ids" readonly="1">
                                <list>
                                    <field name="employee_id"/>
                                    <field name="required"/>
                                    <field name="status"/>
                                    <field name="due_date"/>
                                    <field name="acknowledged_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_policy_version" model="ir.actions.act_window">
        <field name="name">Policy Versions</field>
        <field name="res_model">policy.version</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_policy_version_search"/>
    </record>

    <menuitem id="menu_policy_version" name="Versions" parent="menu_policy_compliance_root" action="action_policy_version" sequence="20"/>
</odoo>

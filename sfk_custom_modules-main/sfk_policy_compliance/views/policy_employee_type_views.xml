<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_policy_employee_type_list" model="ir.ui.view">
        <field name="name">policy.employee.type.list</field>
        <field name="model">policy.employee.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_policy_employee_type_form" model="ir.ui.view">
        <field name="name">policy.employee.type.form</field>
        <field name="model">policy.employee.type</field>
        <field name="arch" type="xml">
            <form string="Employee Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_policy_employee_type" model="ir.actions.act_window">
        <field name="name">Policy Employee Types</field>
        <field name="res_model">policy.employee.type</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_policy_category_list" model="ir.ui.view">
        <field name="name">policy.category.list</field>
        <field name="model">policy.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="policy_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_policy_category_form" model="ir.ui.view">
        <field name="name">policy.category.form</field>
        <field name="model">policy.category</field>
        <field name="arch" type="xml">
            <form string="Policy Category">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_policy_category" model="ir.actions.act_window">
        <field name="name">Policy Categories</field>
        <field name="res_model">policy.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="hr_employee_view_inherit_private_info" model="ir.ui.view">
        <field name="name">hr.employee.view.inherit.private.info</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='personal_information']" position="inside">
                <group string="Tax and Pension Information" >
                <group>
                    <field name="tax_id"/>
                    <field name="pension_id"/>
                </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
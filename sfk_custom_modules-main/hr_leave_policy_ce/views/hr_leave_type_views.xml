<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_leave_type_form_leave_policy" model="ir.ui.view">
        <field name="name">hr.leave.type.form.leave.policy</field>
        <field name="model">hr.leave.type</field>
        <field name="inherit_id" ref="hr_holidays.edit_holiday_status_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='configuration' and @id='configuration']" position="after">
                <group string="Policy Rules">
                    <field name="policy_code"/>
                    <field name="has_custom_limit"/>
                    <field name="max_days" invisible="not has_custom_limit"/>
                    <field name="period_months" invisible="not has_custom_limit"/>
                    <field name="max_instances"/>
                    <field name="max_split_per_year" invisible="policy_code != 'annual'"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_hr_leave_type_list_leave_policy" model="ir.ui.view">
        <field name="name">hr.leave.type.list.leave.policy</field>
        <field name="model">hr.leave.type</field>
        <field name="inherit_id" ref="hr_holidays.view_holiday_status_normal_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='display_name']" position="after">
                <field name="policy_code" optional="show"/>
                <field name="has_custom_limit" optional="hide"/>
                <field name="max_days" optional="hide"/>
                <field name="period_months" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>

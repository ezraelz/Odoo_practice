<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_leave_form_leave_policy" model="ir.ui.view">
        <field name="name">hr.leave.form.leave.policy</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <field name="annual_available_balance" invisible="1"/>
                <field name="policy_pay_note" invisible="1"/>
                <div class="alert alert-info" role="alert" invisible="holiday_status_id.policy_code != 'annual'">
                    <strong>Annual leave balance:</strong>
                    <field name="annual_available_balance" class="oe_inline"/>
                    <span> day(s)</span>
                </div>
                <div class="alert alert-secondary" role="alert" invisible="not policy_pay_note">
                    <field name="policy_pay_note" readonly="1"/>
                </div>
            </xpath>
        </field>
    </record>

    <record id="view_hr_leave_list_leave_policy" model="ir.ui.view">
        <field name="name">hr.leave.list.leave.policy</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='holiday_status_id']" position="after">
                <field name="annual_available_balance" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="rule_annual_entitlement_employee_own_read" model="ir.rule">
            <field name="name">Annual Entitlement: employee can read own</field>
            <field name="model_id" ref="model_hr_leave_annual_entitlement"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_annual_usage_employee_own_read" model="ir.rule">
            <field name="name">Annual Usage: employee can read own</field>
            <field name="model_id" ref="model_hr_leave_annual_usage"/>
            <field name="domain_force">[('leave_id.employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>

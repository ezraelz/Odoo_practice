<odoo>
   <!-- Own Records only -->
    <record id="project_rule_own_only" model="ir.rule">
        <field name="name">Project: Own Records Only</field>
        <field name="model_id" ref="model_project_project"/>
        <field name="groups" eval="[(4, ref('group_project_user_own'))]"/>
        <field name="domain_force">
            [('create_uid', '=', user.id)]
        </field>
    </record>
    <!-- All Records -->
    <record id="project_rule_all" model="ir.rule">
        <field name="name">Project: All Records</field>
        <field name="model_id" ref="model_project_project"/>
        <field name="groups" eval="[(4, ref('group_project_user_all'))]"/>
        <field name="domain_force">
            [(1, '=', 1)]
        </field>
    </record>
    <!-- Locked Records Protection -->
    <record id="project_rule_lock" model="ir.rule">
        <field name="name">Project: Locked Records Protection</field>
        <field name="model_id" ref="model_project_project"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_unlink" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="domain_force">
            ['|', ('is_locked','=',False), ('create_uid','=',user.id)]
        </field>
    </record>
</odoo>
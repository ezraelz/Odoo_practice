<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="equipment_list" model="ir.ui.view">
        <field name="name">equipment.tracker.list</field>
        <field name="model">equipment.tracker</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="equipment_form" model="ir.ui.view">
        <field name="name">equipment.tracker.form</field>
        <field name="model">equipment.tracker</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="serial_number"/>
                        <field name="customer_id"/>
                        <field name="purchase_date"/>
                        <field name="state" readonly="is_locked"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="equipment_action" model="ir.actions.act_window">
        <field name="name">Equipment</field>
        <field name="res_model">equipment.tracker</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="equipment_root" name="Equipment"/>
    <menuitem id="equipment_menu"
              name="Equipment Tracker"
              parent="equipment_root"
              action="equipment_action"/>

</odoo>